{
  "id": "mid_intro_algebra",
  "title": "Intro to Algebra",
  "prerequisites": ["mid_ratios"],
  "steps": [
    {
      "id": "alg_s1",
      "level": 1,
      "type": "exploration",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x", 4], "right": [10] },
      "content": "### What is a Variable?\nIn algebra, a variable (like $x$) is a placeholder for an unknown number. We can find the value of $x$ by performing operations to isolate it on one side of the equation."
    },
    {
      "id": "alg_q1",
      "level": 1,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x", 5], "right": [12] },
      "content": "### Subtracting to Isolate\nTo solve $x + 5 = 12$, we want to get $x$ by itself. We do this by doing the opposite of addition, which is subtraction.",
      "question": {
        "text": "What must you do to both sides of x + 5 = 12 to solve for x?",
        "type": "multiple-choice",
        "choices": ["Add 5 to both sides", "Subtract 5 from both sides", "Multiply both sides by 5", "Divide both sides by 5"],
        "correctAnswer": "Subtract 5 from both sides",
        "hint": "To cancel out '+ 5' on the left, apply its inverse operation.",
        "explanation": "Subtracting 5 from both sides cancels out the $+5$ on the left, leaving $x = 12 - 5$, so $x = 7$.",
        "explanationSteps": [
          "Locate the variable x on the left side of the equation.",
          "Identify the operation performed on x: addition of 5.",
          "Apply the inverse operation: subtraction of 5.",
          "Subtract 5 from both sides to keep the equation balanced.",
          "The equation simplifies to x = 7."
        ]
      }
    },
    {
      "id": "alg_q2",
      "level": 1,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x", -3], "right": [8] },
      "content": "### Solve for x: x - 3 = 8",
      "question": {
        "text": "What is x?",
        "type": "multiple-choice",
        "choices": ["5", "8", "11", "24"],
        "correctAnswer": "11",
        "hint": "Add 3 to both sides.",
        "explanation": "Adding 3 cancels subtraction of 3, leaving x = 11.",
        "explanationSteps": [
          "Equation is x - 3 = 8.",
          "Undo subtraction of 3 by adding 3 to both sides.",
          "x = 8 + 3.",
          "Result is x = 11."
        ]
      }
    },
    {
      "id": "alg_q3",
      "level": 1,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["4x"], "right": [20] },
      "content": "### Solve for x: 4x = 20",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["5", "16", "24", "80"],
        "correctAnswer": "5",
        "hint": "Divide both sides by 4.",
        "explanation": "4x = 20 leads to x = 20/4 = 5.",
        "explanationSteps": [
          "Start with 4x = 20.",
          "Since x is multiplied by 4, perform inverse division.",
          "Divide both sides by 4: 20 / 4.",
          "The result is x = 5."
        ]
      }
    },
    {
      "id": "alg_q4",
      "level": 1,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x/3"], "right": [6] },
      "content": "### Solve for x: x/3 = 6",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["2", "3", "9", "18"],
        "correctAnswer": "18",
        "hint": "Multiply both sides by 3.",
        "explanation": "x/3 = 6 leads to x = 6 * 3 = 18.",
        "explanationSteps": [
          "Start with x/3 = 6.",
          "Since x is divided by 3, perform inverse multiplication.",
          "Multiply both sides by 3: 6 * 3.",
          "The result is x = 18."
        ]
      }
    },
    {
      "id": "alg_q5",
      "level": 1,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x", 9], "right": [15] },
      "content": "### Solve for x: x + 9 = 15",
      "question": {
        "text": "Find x:",
        "type": "multiple-choice",
        "choices": ["6", "9", "15", "24"],
        "correctAnswer": "6",
        "hint": "Subtract 9 from both sides.",
        "explanation": "x + 9 = 15 leads to x = 15 - 9 = 6.",
        "explanationSteps": [
          "Equation is x + 9 = 15.",
          "Subtract 9 from both sides.",
          "x = 15 - 9.",
          "Result is x = 6."
        ]
      }
    },
    {
      "id": "alg_q6",
      "level": 2,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["3x", 2], "right": [14] },
      "content": "### Solving Two-Step Equations\nConsider $3x + 2 = 14$. Here, $x$ is multiplied by 3 and has 2 added to it. We undo the operations in reverse order: first undo addition/subtraction, then undo multiplication/division.",
      "question": {
        "text": "Solve for x: 3x + 2 = 14",
        "type": "multiple-choice",
        "choices": ["3", "4", "5", "6"],
        "correctAnswer": "4",
        "hint": "First subtract 2 from both sides to get 3x = 12. Then divide both sides by 3.",
        "explanation": "Subtracting 2 gives $3x = 12$. Dividing by 3 gives $x = 4$.",
        "explanationSteps": [
          "Isolate the variable term (3x) by removing the addition: subtract 2 from both sides.",
          "3x = 14 - 2 -> 3x = 12.",
          "Isolate x by removing the multiplication: divide both sides by 3.",
          "x = 12 / 3 -> x = 4."
        ]
      }
    },
    {
      "id": "alg_q7",
      "level": 2,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["2x", -5], "right": [11] },
      "content": "### Solve for x: 2x - 5 = 11",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["3", "6", "8", "16"],
        "correctAnswer": "8",
        "hint": "Add 5, then divide by 2.",
        "explanation": "2x = 16, so x = 8.",
        "explanationSteps": [
          "Start with 2x - 5 = 11.",
          "Add 5 to both sides: 2x = 16.",
          "Divide by 2: x = 16 / 2.",
          "Result is x = 8."
        ]
      }
    },
    {
      "id": "alg_q8",
      "level": 2,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["5x", 3], "right": [23] },
      "content": "### Solve for x: 5x + 3 = 23",
      "question": {
        "text": "Find x:",
        "type": "multiple-choice",
        "choices": ["3", "4", "5", "6"],
        "correctAnswer": "4",
        "hint": "Subtract 3, then divide by 5.",
        "explanation": "5x = 20, so x = 4.",
        "explanationSteps": [
          "Equation is 5x + 3 = 23.",
          "Subtract 3 from both sides: 5x = 20.",
          "Divide by 5: x = 4."
        ]
      }
    },
    {
      "id": "alg_q9",
      "level": 2,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x/2", -4], "right": [1] },
      "content": "### Solve for x: x/2 - 4 = 1",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["5", "6", "10", "12"],
        "correctAnswer": "10",
        "hint": "Add 4, then multiply by 2.",
        "explanation": "x/2 = 5, so x = 10.",
        "explanationSteps": [
          "Start with x/2 - 4 = 1.",
          "Add 4 to both sides: x/2 = 5.",
          "Multiply both sides by 2: x = 5 * 2.",
          "The answer is x = 10."
        ]
      }
    },
    {
      "id": "alg_q10",
      "level": 2,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["4x", -7], "right": [9] },
      "content": "### Solve for x: 4x - 7 = 9",
      "question": {
        "text": "Find x:",
        "type": "multiple-choice",
        "choices": ["2", "4", "6", "8"],
        "correctAnswer": "4",
        "hint": "Add 7, then divide by 4.",
        "explanation": "4x = 16, so x = 4.",
        "explanationSteps": [
          "Start with 4x - 7 = 9.",
          "Add 7 to both sides: 4x = 16.",
          "Divide both sides by 4: x = 16 / 4.",
          "The result is x = 4."
        ]
      }
    },
    {
      "id": "alg_q11",
      "level": 3,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["2x", 3], "right": ["x", 8] },
      "content": "### Variables on Both Sides\nTo solve $2x + 3 = x + 8$, we must first gather all terms containing $x$ on one side, and constant numbers on the other side.",
      "question": {
        "text": "Solve for x: 2x + 3 = x + 8",
        "type": "multiple-choice",
        "choices": ["3", "4", "5", "11"],
        "correctAnswer": "5",
        "hint": "Subtract 'x' from both sides to get all x terms on the left. Then isolate x.",
        "explanation": "Subtracting $x$ from both sides gives $x + 3 = 8$. Then subtracting 3 from both sides gives $x = 5$.",
        "explanationSteps": [
          "Gather variables on the left: subtract x from both sides.",
          "2x + 3 - x = x + 8 - x -> x + 3 = 8.",
          "Gather constants on the right: subtract 3 from both sides.",
          "x = 8 - 3 -> x = 5."
        ]
      }
    },
    {
      "id": "alg_q12",
      "level": 3,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["3x", -4], "right": ["2x", 5] },
      "content": "### Solve for x: 3x - 4 = 2x + 5",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["1", "5", "9", "11"],
        "correctAnswer": "9",
        "hint": "Subtract 2x, then add 4.",
        "explanation": "x - 4 = 5 leads to x = 9.",
        "explanationSteps": [
          "Subtract 2x from both sides: x - 4 = 5.",
          "Add 4 to both sides: x = 5 + 4.",
          "Result is x = 9."
        ]
      }
    },
    {
      "id": "alg_q13",
      "level": 3,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["5x", 2], "right": ["2x", 11] },
      "content": "### Solve for x: 5x + 2 = 2x + 11",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["3", "4", "5", "9"],
        "correctAnswer": "3",
        "hint": "Subtract 2x first, then subtract 2, then divide by 3.",
        "explanation": "3x = 9, so x = 3.",
        "explanationSteps": [
          "Start with 5x + 2 = 2x + 11.",
          "Subtract 2x from both sides: 3x + 2 = 11.",
          "Subtract 2 from both sides: 3x = 9.",
          "Divide by 3: x = 3."
        ]
      }
    },
    {
      "id": "alg_q14",
      "level": 3,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["4x", -6], "right": ["2x", 8] },
      "content": "### Solve for x: 4x - 6 = 2x + 8",
      "question": {
        "text": "Find x:",
        "type": "multiple-choice",
        "choices": ["2", "4", "7", "14"],
        "correctAnswer": "7",
        "hint": "Subtract 2x, then add 6, then divide.",
        "explanation": "2x = 14, so x = 7.",
        "explanationSteps": [
          "Subtract 2x from both sides: 2x - 6 = 8.",
          "Add 6 to both sides: 2x = 14.",
          "Divide both sides by 2: x = 14 / 2 = 7."
        ]
      }
    },
    {
      "id": "alg_q15",
      "level": 3,
      "type": "question",
      "widget": "AlgebraBalance",
      "widgetParams": { "left": ["x", 12], "right": ["3x", -4] },
      "content": "### Solve for x: x + 12 = 3x - 4",
      "question": {
        "text": "Solve for x:",
        "type": "multiple-choice",
        "choices": ["4", "6", "8", "16"],
        "correctAnswer": "8",
        "hint": "Subtract x, then add 4, then divide by 2.",
        "explanation": "2x = 16, so x = 8.",
        "explanationSteps": [
          "Equation is x + 12 = 3x - 4.",
          "Subtract x from both sides: 12 = 2x - 4.",
          "Add 4 to both sides: 16 = 2x.",
          "Divide both sides by 2: x = 8."
        ]
      }
    }
  ]
}
